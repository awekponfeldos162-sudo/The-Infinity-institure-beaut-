# Copier ce fichier en ".env" et renseigner les valeurs disponibles dans
# la console Firebase (Paramètres du projet > Vos applications > Config SDK).
# Ne jamais committer le fichier ".env" réel dans un dépôt public.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Numéro WhatsApp de l'institut, format international sans "+" ni espaces
# Exemple Bénin : 22997000000
VITE_WHATSAPP_NUMBER= 22997903667
